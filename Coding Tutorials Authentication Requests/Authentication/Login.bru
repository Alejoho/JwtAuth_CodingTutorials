meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/authentication/login
  body: json
  auth: inherit
}

body:json {
  {
    "username": "{{username}}",
    "password": "{{password}}"
  }
}

script:post-response {
  const content = res.body;
  
  bru.setEnvVar("accessToken", content.jwtToken);
  
  bru.setEnvVar("refreshToken", content.refreshToken);
}

settings {
  encodeUrl: true
  timeout: 0
}
