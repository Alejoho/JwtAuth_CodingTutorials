meta {
  name: Refresh
  type: http
  seq: 2
}

post {
  url: https://10.10.10.102:7259/api/authentication/refresh
  body: json
  auth: inherit
}

body:json {
  {
    "accessToken": "{{accessToken}}",
    "refreshToken": "{{refreshToken}}"
  }
}

script:post-response {
  const content = res.body;
  
  bru.setEnvVar("accessToken", content.jwtToken);
  
  bru.setEnvVar("refreshToken", content.refreshToken);
}

settings {
  encodeUrl: true
  timeout: 0
}
