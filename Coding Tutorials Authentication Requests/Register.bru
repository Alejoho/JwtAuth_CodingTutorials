meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: https:10.10.10.102:7259/api/authentication/register
  body: json
  auth: inherit
}

body:json {
  {
    "username": "{{username}}",
    "password": "{{password}}",
    "email": "{{email}}"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
